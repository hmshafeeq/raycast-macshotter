{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "macshotter",
  "title": "MacShotter",
  "description": "Trigger macshot capture, recording, OCR and history actions via its macshot:// URL scheme.",
  "icon": "extension-icon.png",
  "author": "v_sol",
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "macshotter",
      "title": "MacShotter",
      "description": "Open MacShotter capture, recording, OCR and history actions.",
      "mode": "view",
      "keywords": [
        "screenshot",
        "capture",
        "recording",
        "ocr",
        "macshot"
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.83.1",
    "@raycast/utils": "^1.17.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.5.4",
    "@types/react": "^19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "scripts": {
    "build": "ray build --skip-types -e dist -o dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
